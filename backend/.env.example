# --- Database ---
# Default (no setup needed): SQLite file in the backend folder.
# For Postgres (docker compose does this for you):
# DATABASE_URL=postgresql+psycopg2://trader:trader@localhost:5432/trading
DATABASE_URL=sqlite:///./trading.db

# --- Cache (optional). If unset/unreachable, an in-memory cache is used. ---
# REDIS_URL=redis://localhost:6379/0

# --- Optional: enables LLM-based news sentiment (get a key at console.anthropic.com) ---
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-4-6

# --- Paper trading account ---
STARTING_CASH=1000000
BASE_CURRENCY=INR

# --- Market context symbol (NIFTY 50). Use ^GSPC for S&P 500, etc. ---
MARKET_INDEX_SYMBOL=^NSEI

# --- Optional: Telegram alerts from the Autopilot (see README) ---
# TELEGRAM_BOT_TOKEN=123456:ABC-xyz
# TELEGRAM_CHAT_ID=123456789

# --- Optional: Groww API — real NSE+BSE data + full-market scanning ---
# Get a token at https://groww.in/trade-api (₹499/mo). Paste the daily access token:
# GROWW_API_TOKEN=your_groww_access_token
# How many symbols to scan per cycle in "entire market" mode (rotates through all ~7000):
# UNIVERSE_SCAN_SLICE=250
